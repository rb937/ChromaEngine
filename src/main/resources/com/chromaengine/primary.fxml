<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="10.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.chromaengine.ui.PrimaryController" style="-fx-background-color: #121212;">

   <ScrollPane fx:id="scrollPane" fitToHeight="true" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background: #1e1e1e; -fx-border-color: #333333;">
      <StackPane>
         <ImageView fx:id="imageView" preserveRatio="true" />
      </StackPane>
   </ScrollPane>

   <VBox spacing="15.0" style="-fx-background-color: #1a1a1a; -fx-padding: 15; -fx-border-color: #333333; -fx-border-width: 1 0 0 0;">
       
       <HBox alignment="CENTER" spacing="25.0">
           <VBox spacing="5.0">
               <Label text="Filter Option" style="-fx-text-fill: #cccccc; -fx-font-size: 12px;"/>
               <ComboBox fx:id="filterModeDropdown" prefWidth="150" style="-fx-background-color: #292929; -fx-base: #1e1e1e; -fx-prompt-text-fill: #cccccc;"/>
           </VBox>

           <VBox spacing="5.0">
               <Label fx:id="slider1Label" text="Intensity" style="-fx-text-fill: #007acc; -fx-font-weight: bold; -fx-font-size: 12px;"/>
               <Slider fx:id="intensitySlider" min="-100" max="100" value="0" showTickMarks="true" showTickLabels="true" majorTickUnit="50" prefWidth="200"/>
           </VBox>

           <VBox spacing="5.0">
               <Label fx:id="slider2Label" text="Brightness" style="-fx-text-fill: #007acc; -fx-font-weight: bold; -fx-font-size: 12px;"/>
               <Slider fx:id="brightnessSlider" min="-100" max="100" value="0" showTickMarks="true" showTickLabels="true" majorTickUnit="50" prefWidth="200"/>
           </VBox>

           <VBox spacing="5.0">
               <Label text="Zoom" style="-fx-text-fill: #696969; -fx-font-size: 12px;"/>
               <Slider fx:id="zoomSlider" min="0.1" max="3.0" value="1.0" prefWidth="150"/>
           </VBox>
       </HBox>

       <HBox alignment="CENTER" spacing="15.0">
           <Button fx:id="loadButton" text="Open Image..." onAction="#openImage" style="-fx-background-color: #3875ef; -fx-text-fill: white; -fx-cursor: hand; padding: 8 20 8 20;"/>
           <Button fx:id="resetButton" text="Reset Image" onAction="#resetImage" style="-fx-background-color: #cc0000; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; padding: 8 20 8 20;"/>
           <Button fx:id="saveButton" text="Save Image..." onAction="#saveImage" style="-fx-background-color: #2e8b57; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; padding: 8 20 8 20;"/>
           <Button fx:id="ApplyButton" text="Commit Layer" onAction="#commitLayer" style="-fx-background-color: #d3ca47; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; padding: 8 20 8 20;"/>
       </HBox>
   </VBox>
</VBox>